# PicoDB configuration — copy to `.env` and edit. `./picodb run` loads it.
# Every runtime setting lives here (like redis.conf), so no code changes needed.

# --- Network ----------------------------------------------------------------
# Address to bind both listeners to.
#   127.0.0.1  -> loopback only (safe default; reachable only from this host)
#   0.0.0.0    -> all interfaces (exposes PicoDB to your network / the internet)
# Only expose publicly with PICODB_TOKEN set, and ideally TLS via a proxy.
PICODB_BIND=127.0.0.1

# TCP port for the raw binary database engine.
PICODB_ENGINE_PORT=7120

# TCP port for the HTTP dashboard, /metrics, /api/keys, and the WebSocket.
PICODB_HTTP_PORT=7121

# --- Security ---------------------------------------------------------------
# Shared access token. When set, ALL surfaces (engine, dashboard, WebSocket)
# require it. Leave empty to run with auth DISABLED (loopback dev only).
# `./picodb setup` generates a strong random token here automatically.
PICODB_TOKEN=

# --- Memory -----------------------------------------------------------------
# Hard RAM cap for the cache, in bytes. Oldest keys are evicted (LRU) past this.
# 52428800 = 50 MiB.
PICODB_MAX_BYTES=52428800
