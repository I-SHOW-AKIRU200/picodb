# PicoDB configuration — copy to `.env` and edit. `run.sh` / `make run` load it.

# Shared access token. When set, ALL surfaces (binary engine, HTTP dashboard,
# WebSocket) require it. Leave unset/empty to run with auth DISABLED (loopback
# dev only). setup.sh generates a strong random token here automatically.
PICODB_TOKEN=

# Hard RAM cap for the cache, in bytes. Oldest keys are evicted (LRU) past this.
# Default 50 MiB if unset.
PICODB_MAX_BYTES=52428800
