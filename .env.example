# PicoDB configuration — copy to `.env` and edit. `./picodb run` loads it.
# Every runtime setting lives here (like redis.conf), so no code changes needed.

# --- Network ----------------------------------------------------------------
# Address to bind both listeners to.
#   127.0.0.1  -> loopback only (safe default; reachable only from this host)
#   0.0.0.0    -> all interfaces (exposes PicoDB to your network / the internet)
# Only expose publicly with PICODB_TOKEN set, and ideally TLS via a proxy.
PICODB_BIND=127.0.0.1

# TCP port for the raw binary database engine.
PICODB_ENGINE_PORT=7120

# TCP port for the HTTP dashboard, /metrics, /api/keys, and the WebSocket.
PICODB_HTTP_PORT=7121

# --- Security ---------------------------------------------------------------
# Auth secret. Choose ONE style:
#
#  (a) Single token — `./picodb setup` generates one here automatically:
PICODB_TOKEN=
#
#  (b) Username + password (Redis-style). Used only if PICODB_TOKEN is empty.
#      The effective secret becomes "username:password", so clients connect with
#      picodb://username:password@host:port
# PICODB_USERNAME=admin
# PICODB_PASSWORD=change-me
#
# When any secret is set, ALL surfaces (engine, dashboard, WebSocket) require it.
# Leave everything empty to run with auth DISABLED (loopback dev only).

# --- Memory -----------------------------------------------------------------
# Hard RAM cap for the cache, in bytes. Oldest keys are evicted (LRU) past this.
# 52428800 = 50 MiB.
PICODB_MAX_BYTES=52428800

# --- Persistence (AOF) ------------------------------------------------------
# Append-only file: every mutating command is logged, and replayed on startup so
# data survives a restart. DISABLED by default (pure in-memory). Set a path to
# enable it. Leave empty/unset to keep PicoDB purely in-memory.
# PICODB_AOF_PATH=picodb.aof
#
# Durability policy — the classic speed-vs-safety tradeoff:
#   everysec : fsync at most once per second (default). A power loss loses ≤1s;
#              a process crash loses nothing. Best balance for a cache.
#   always   : fsync after every write batch. Strongest, but throughput is
#              bounded by disk fsync latency.
#   no       : never fsync; the OS flushes on its own. Fastest. A process crash
#              loses nothing, but a power loss / OS crash can lose recent writes.
# PICODB_AOF_FSYNC=everysec
#
# The log is auto-compacted (rewritten to the minimal state) once it grows past
# this size AND has at least doubled since the last rewrite. 67108864 = 64 MiB.
# You can also trigger a compaction on demand: POST /aof/rewrite (authorized).
# PICODB_AOF_REWRITE_MIN_BYTES=67108864
#
# Minimum interval between manual rewrites via POST /aof/rewrite, in seconds.
# Prevents rapid hammering of the rewrite endpoint. The background auto-compaction
# loop is unaffected by this limit. Default: 30.
# PICODB_AOF_REWRITE_MIN_INTERVAL_SECS=30
